generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Student {
  id         String @id @default(cuid())
  name       String
  email      String @unique
  studentId  String @unique
  course     String
  year       String
  event      String
  createdAt  DateTime @default(now())
}